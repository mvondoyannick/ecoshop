<div class="w-full max-w-5xl mx-auto">
  <div class="flex items-center gap-4 mb-8">
    <%= link_to @supermarch, class: "p-2 bg-gray-100 rounded-lg text-gray-500 hover:bg-gray-200 transition-colors" do %>
      <%= heroicon "chevron-left", options: { class: "w-6 h-6" } %>
    <% end %>
    <h1 class="font-black text-4xl text-gray-900 tracking-tight">Modifier le Supermarché</h1>
  </div>

  <div class="bg-white rounded-2xl shadow-xl p-8 border border-gray-100">
    <%= render "form", supermarch: @supermarch %>
  </div>
</div>
