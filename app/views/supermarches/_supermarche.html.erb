<div id="<%= dom_id supermarche %>" class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100 transition-all hover:shadow-2xl">
  <div class="md:flex">
    <!-- Left side: Info -->
    <div class="md:w-1/2 p-8">
      <div class="flex items-center gap-4 mb-6">
        <% if supermarche.logo.attached? %>
          <%= image_tag supermarche.logo, alt: "#{supermarche.name} Logo", class: "w-16 h-16 rounded-xl object-cover shadow-sm border border-gray-100" %>
        <% else %>
          <div class="w-16 h-16 rounded-xl bg-green-50 flex items-center justify-center text-green-600 font-bold text-2xl shadow-sm">
            <%= supermarche.name[0] %>
          </div>
        <% end %>
        <div>
          <h2 class="text-2xl font-black text-gray-900 leading-tight"><%= supermarche.name %></h2>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-green-100 text-green-800 uppercase tracking-wider mt-1">
          CODE: <%= supermarche.code %>
          </span>
          <% if current_user.admin? %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-gray-100 text-gray-800 uppercase tracking-wider mt-1 ml-2">
              Statut: <%= supermarche.status %>
            </span>
          <% end %>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-6 text-sm">
        <div class="flex items-start gap-3">
          <div class="p-2 bg-gray-50 rounded-lg text-gray-400">
            <%= heroicon "map-pin", options: { class: "w-5 h-5" } %>
          </div>
          <div>
            <p class="font-bold text-gray-900">Localisation</p>
            <p class="text-gray-500"><%= supermarche.lieu_dit %>, <%= supermarche.quartier %></p>
            <p class="text-gray-500 font-medium"><%= supermarche.ville&.name %></p>
          </div>
        </div>

        <div class="flex items-start gap-3">
          <div class="p-2 bg-gray-50 rounded-lg text-gray-400">
            <%= heroicon "phone", options: { class: "w-5 h-5" } %>
          </div>
          <div>
            <p class="font-bold text-gray-900">Contact</p>
            <p class="text-gray-500"><%= supermarche.phone %></p>
            <p class="text-gray-500 italic"><%= supermarche.email %></p>
          </div>
        </div>

        <div class="flex items-start gap-3 pt-4 border-t border-gray-50">
          <div class="flex-1">
            <p class="text-xs font-black text-gray-400 uppercase tracking-widest mb-3">Statistiques</p>
            <div class="flex gap-4">
              <div class="flex-1 bg-green-50 rounded-xl p-4 transition-all hover:bg-green-100">
                <p class="text-2xl font-black text-green-600"><%= supermarche.liste_de_prix.count %></p>
                <p class="text-xs font-bold text-green-400 uppercase">Listes de prix</p>
              </div>
              <div class="flex-1 bg-green-50 rounded-xl p-4 transition-all hover:bg-green-100">
                <p class="text-2xl font-black text-green-600"><%= supermarche.liste_de_prix_items.count %></p>
                <p class="text-xs font-bold text-green-400 uppercase">Produits</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right side: Map -->
    <div class="md:w-1/2 h-64 md:h-auto min-h-[300px] bg-gray-100 relative">
      <% if supermarche.latitude.present? && supermarche.longitude.present? %>
        <iframe 
          width="100%" 
          height="100%" 
          frameborder="0" 
          style="border:0"
          src="https://www.google.com/maps?q=<%= supermarche.latitude %>,<%= supermarche.longitude %>&hl=fr&z=14&output=embed" 
          allowfullscreen>
        </iframe>
      <% else %>
        <div class="flex flex-col items-center justify-center h-full text-gray-400 p-8 text-center">
          <%= heroicon "map", options: { class: "w-12 h-12 mb-3 opacity-20" } %>
          <p>Coordonnées GPS manquantes pour afficher la carte.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
