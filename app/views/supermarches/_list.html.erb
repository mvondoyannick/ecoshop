<div data-controller="datatables" class="space-y-4">
  <div class="flex justify-end">
    <div class="relative w-full max-w-sm">
      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
        <%= heroicon "magnifying-glass", options: { class: "h-5 w-5 text-gray-400" } %>
      </div>
      <input 
        data-datatables-target="input" 
        data-action="input->datatables#search"
        type="text" 
        placeholder="Rechercher un supermarché..." 
        class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-xl leading-5 bg-white placeholder-gray-500 focus:outline-none focus:ring-1 focus:ring-green-500 focus:border-green-500 sm:text-sm transition-all"
      >
    </div>
  </div>

  <div class="overflow-x-auto bg-white rounded-xl shadow-sm border border-gray-100">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="px-6 py-3 text-left text-xs font-black text-gray-500 uppercase tracking-wider cursor-pointer hover:bg-gray-100 transition-colors group" data-action="click->datatables#sort" data-column="name">
            <div class="flex items-center gap-2">
              Supermarché
              <%= heroicon "chevron-up-down", options: { class: "w-3 h-3 opacity-20 group-hover:opacity-100 transition-all" } %>
            </div>
          </th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-black text-gray-500 uppercase tracking-wider cursor-pointer hover:bg-gray-100 transition-colors group" data-action="click->datatables#sort" data-column="ville">
            <div class="flex items-center gap-2">
              Ville / Quartier
              <%= heroicon "chevron-up-down", options: { class: "w-3 h-3 opacity-20 group-hover:opacity-100 transition-all" } %>
            </div>
          </th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-black text-gray-500 uppercase tracking-wider cursor-pointer hover:bg-gray-100 transition-colors group" data-action="click->datatables#sort" data-column="listes" data-type="number">
            <div class="flex items-center gap-2">
              Listes de prix
              <%= heroicon "chevron-up-down", options: { class: "w-3 h-3 opacity-20 group-hover:opacity-100 transition-all" } %>
            </div>
          </th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-black text-gray-500 uppercase tracking-wider cursor-pointer hover:bg-gray-100 transition-colors group" data-action="click->datatables#sort" data-column="produits" data-type="number">
            <div class="flex items-center gap-2">
              Produits
              <%= heroicon "chevron-up-down", options: { class: "w-3 h-3 opacity-20 group-hover:opacity-100 transition-all" } %>
            </div>
          </th>
          <% if current_user.admin? %>
            <th scope="col" class="px-6 py-3 text-left text-xs font-black text-gray-500 uppercase tracking-wider">Enregistré par</th>
          <% end %>
          <% if current_user.admin? %>
            <th scope="col" class="px-6 py-3 text-left text-xs font-black text-gray-500 uppercase tracking-wider">Statut</th>
          <% end %>
          <th scope="col" class="px-6 py-3 text-right text-xs font-black text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% supermarches.each do |supermarche| %>
          <tr data-datatables-target="row" class="hover:bg-gray-50 transition-colors group">
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="flex items-center gap-3">
                <% if supermarche.logo.attached? %>
                  <%= image_tag supermarche.logo, class: "w-10 h-10 rounded-lg object-cover" %>
                <% else %>
                  <div class="w-10 h-10 rounded-lg bg-green-50 flex items-center justify-center text-green-600 font-bold">
                    <%= supermarche.name[0] %>
                  </div>
                <% end %>
                <div>
                  <div class="text-sm font-bold text-gray-900"><%= supermarche.name %></div>
                  <div class="text-xs text-gray-400 font-mono"><%= supermarche.code %></div>
                </div>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm text-gray-900 font-medium"><%= supermarche.ville&.name %></div>
              <div class="text-xs text-gray-500"><%= supermarche.quartier %></div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                <%= supermarche.liste_de_prix.count %> listes
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-800">
                <%= supermarche.liste_de_prix_items.count %> produits
              </div>
            </td>
            <% if current_user.admin? %>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-xs text-gray-900 font-bold"><%= supermarche.user&.name || "N/A" %></div>
                <div class="text-[10px] text-gray-400"><%= supermarche.societe&.name %></div>
              </td>
            <% end %>
            <% if current_user.admin? %>
              <td class="px-6 py-4 whitespace-nowrap">
                <% color = case supermarche.status when "Actif" then "bg-green-100 text-green-700" when "Suspendu" then "bg-yellow-100 text-yellow-700" when "Archivé" then "bg-gray-100 text-gray-500" else "bg-green-50 text-green-700" end %>
                <span class="px-2.5 py-0.5 rounded-full text-xs font-bold <%= color %>">
                  <%= supermarche.status %>
                </span>
              </td>
            <% end %>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              <div class="flex justify-end gap-2">
                <%= link_to supermarche, title: "Voir", class: "p-1.5 text-gray-400 hover:text-green-600 transition-colors" do %>
                  <%= heroicon "eye", options: { class: "w-5 h-5" } %>
                <% end %>
                <%= link_to edit_supermarch_path(supermarche), title: "Modifier", class: "p-1.5 text-gray-400 hover:text-green-600 transition-colors" do %>
                  <%= heroicon "pencil-square", options: { class: "size-5" } %>
                <% end %>
                
                <div class="relative group/actions inline-block">
                  <button class="p-1.5 text-gray-400 hover:text-gray-600 transition-colors">
                    <%= heroicon "ellipsis-vertical", options: { class: "w-5 h-5" } %>
                  </button>
                  <div class="absolute right-0 bottom-full mb-2 hidden group-hover/actions:block w-40 bg-white border border-gray-100 rounded-lg shadow-xl z-50 p-1">
                    <% if supermarche.status == "Actif" %>
                      <%= button_to suspend_supermarch_path(supermarche), method: :patch, class: "w-full text-left px-3 py-2 text-xs font-semibold text-yellow-600 hover:bg-yellow-50 rounded-md transition-colors flex items-center gap-2" do %>
                        <%= heroicon "pause-circle", options: { class: "w-4 h-4" } %> Suspendre
                      <% end %>
                    <% else %>
                      <%= button_to reactivate_supermarch_path(supermarche), method: :patch, class: "w-full text-left px-3 py-2 text-xs font-semibold text-green-600 hover:bg-green-50 rounded-md transition-colors flex items-center gap-2" do %>
                        <%= heroicon "play-circle", options: { class: "w-4 h-4" } %> Réactiver
                      <% end %>
                    <% end %>
                    
                    <% if supermarche.status != "Archivé" %>
                      <%= button_to archive_supermarch_path(supermarche), method: :patch, class: "w-full text-left px-3 py-2 text-xs font-semibold text-red-600 hover:bg-red-50 rounded-md transition-colors flex items-center gap-2" do %>
                        <%= heroicon "archive-box", options: { class: "w-4 h-4" } %> Archiver
                      <% end %>
                    <% end %>
                  </div>
                </div>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
