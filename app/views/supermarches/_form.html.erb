<%= form_with(model: supermarch, class: "contents") do |form| %>
  <% if supermarch.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-3">
      <h2 class="font-bold"><%= pluralize(supermarch.errors.count, "error") %> prohibited this supermarch from being saved:</h2>
      <ul class="list-disc ml-6">
        <% supermarch.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
    <div class="space-y-5">
      <div>
        <%= form.label :name, "Nom du supermarché", class: "block font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :name, class: "block shadow-sm rounded-lg border border-gray-300 px-4 py-2 mt-1 w-full focus:ring-blue-500 focus:border-blue-500 transition-all shadow-sm" %>
      </div>

      <div>
        <%= form.label :logo, "Logo (Fichier)", class: "block font-semibold text-gray-700 mb-1" %>
        <%= form.file_field :logo, class: "block shadow-sm rounded-lg border border-gray-300 px-4 py-2 mt-1 w-full focus:ring-blue-500 focus:border-blue-500 transition-all shadow-sm" %>
      </div>

      <div>
        <%= form.label :email, class: "block font-semibold text-gray-700 mb-1" %>
        <%= form.email_field :email, class: "block shadow-sm rounded-lg border border-gray-300 px-4 py-2 mt-1 w-full focus:ring-blue-500 focus:border-blue-500 transition-all shadow-sm" %>
      </div>

      <div>
        <%= form.label :phone, "Téléphone", class: "block font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :phone, class: "block shadow-sm rounded-lg border border-gray-300 px-4 py-2 mt-1 w-full focus:ring-blue-500 focus:border-blue-500 transition-all shadow-sm" %>
      </div>

      <div>
        <%= form.label :ville_id, "Ville", class: "block font-semibold text-gray-700 mb-1" %>
        <%= form.collection_select :ville_id, Ville.all, :id, :name, { prompt: "Sélectionnez une ville" }, class: "block shadow-sm rounded-lg border border-gray-300 px-4 py-2 mt-1 w-full focus:ring-blue-500 focus:border-blue-500 transition-all shadow-sm bg-white" %>
      </div>
    </div>

    <div class="space-y-5">
      <div>
        <%= form.label :code, class: "block font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :code, readonly: true, placeholder: "Auto-généré", class: "block shadow-sm rounded-lg border border-gray-100 bg-gray-50 px-4 py-2 mt-1 w-full text-gray-500 cursor-not-allowed" %>
      </div>

      <div>
        <%= form.label :quartier, class: "block font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :quartier, class: "block shadow-sm rounded-lg border border-gray-300 px-4 py-2 mt-1 w-full focus:ring-blue-500 focus:border-blue-500 transition-all shadow-sm" %>
      </div>

      <div>
        <%= form.label :lieu_dit, class: "block font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :lieu_dit, class: "block shadow-sm rounded-lg border border-gray-300 px-4 py-2 mt-1 w-full focus:ring-blue-500 focus:border-blue-500 transition-all shadow-sm" %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= form.label :latitude, class: "block font-semibold text-gray-700 mb-1" %>
          <%= form.text_field :latitude, class: "block shadow-sm rounded-lg border border-gray-300 px-4 py-2 mt-1 w-full focus:ring-blue-500 focus:border-blue-500 transition-all shadow-sm" %>
        </div>
        <div>
          <%= form.label :longitude, class: "block font-semibold text-gray-700 mb-1" %>
          <%= form.text_field :longitude, class: "block shadow-sm rounded-lg border border-gray-300 px-4 py-2 mt-1 w-full focus:ring-blue-500 focus:border-blue-500 transition-all shadow-sm" %>
        </div>
      </div>

      <% if current_user.admin? %>
        <div>
          <%= form.label :status, "Statut (Admin)", class: "block font-semibold text-gray-700 mb-1" %>
          <%= form.select :status, Supermarche::STATUSES, {}, class: "block shadow-sm rounded-lg border border-gray-300 px-4 py-2 mt-1 w-full focus:ring-blue-500 focus:border-blue-500 transition-all shadow-sm bg-white" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-10 flex gap-4">
    <%= form.submit "Enregistrer", class: "rounded-lg py-3 px-8 bg-blue-600 text-white font-bold shadow-lg hover:bg-blue-700 hover:shadow-xl transform hover:-translate-y-0.5 transition-all cursor-pointer" %>
    <%= link_to "Annuler", supermarches_path, class: "rounded-lg py-3 px-8 bg-gray-100 text-gray-700 font-semibold hover:bg-gray-200 transition-all" %>
  </div>
<% end %>
