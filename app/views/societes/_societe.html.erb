<div id="<%= dom_id societe %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= societe.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Phone:</strong>
    <%= societe.phone %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Ville:</strong>
    <%= societe.ville_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Email:</strong>
    <%= societe.email %>
  </div>
</div>
