<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-700 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center mb-10">
    <h1 class="font-black text-4xl text-gray-900 tracking-tight">Catalogue Produits</h1>
    <%= link_to new_produit_path, class: "flex items-center gap-2 rounded-xl py-3 px-6 bg-green-600 text-white font-bold shadow-lg hover:bg-green-700 hover:shadow-xl transition-all" do %>
      <%= heroicon "plus", options: { class: "w-5 h-5" } %>
      <span>Nouveau Produit</span>
    <% end %>
  </div>

  <div class="overflow-hidden bg-white rounded-2xl shadow-sm border border-gray-100">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-4 text-left text-xs font-black text-gray-400 uppercase tracking-widest">Image</th>
          <th class="px-6 py-4 text-left text-xs font-black text-gray-400 uppercase tracking-widest">Produit</th>
          <th class="px-6 py-4 text-left text-xs font-black text-gray-400 uppercase tracking-widest">Catégorie</th>
          <th class="px-6 py-4 text-left text-xs font-black text-gray-400 uppercase tracking-widest">Format (UDM)</th>
          <% if current_user.admin? %>
            <th class="px-6 py-4 text-left text-xs font-black text-gray-400 uppercase tracking-widest">Enregistré par</th>
          <% end %>
          <th class="px-6 py-4 text-left text-xs font-black text-gray-400 uppercase tracking-widest">Etat</th>
          <th class="px-6 py-4 text-right text-xs font-black text-gray-400 uppercase tracking-widest">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @produits.each do |produit| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-6 py-4 whitespace-nowrap">
              <% if produit.image.attached? %>
                <%= image_tag produit.image.variant(resize_to_fill: [64, 64]), class: "w-16 h-16 rounded-xl object-cover shadow-sm" %>
              <% else %>
                <div class="w-16 h-16 rounded-xl bg-gray-100 flex items-center justify-center text-gray-400 shadow-sm border border-gray-50">
                  <%= heroicon "photo", options: { class: "size-8 opacity-20" } %>
                </div>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm font-bold text-gray-900"><%= produit.name %></div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="px-2.5 py-1 rounded-lg bg-blue-50 text-blue-700 text-xs font-bold"><%= produit.category %></span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm text-gray-500 font-medium"><%= produit.udm_value %> (<%= produit.udm %>)</div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <% if produit.perime? %>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-red-50 text-red-700 text-xs font-bold ring-1 ring-inset ring-red-600/10">
                  <span class="size-1.5 rounded-full bg-red-500"></span>
                  Périmé
                </span>
              <% else %>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-green-50 text-green-700 text-xs font-bold ring-1 ring-inset ring-green-600/10">
                  <span class="size-1.5 rounded-full bg-green-500"></span>
                  Bon état
                </span>
              <% end %>
            </td>
            <% if current_user.admin? %>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-xs text-gray-900 font-bold"><%= produit.user&.name || "N/A" %></div>
                <div class="text-[10px] text-gray-400"><%= produit.societe&.name %></div>
              </td>
            <% end %>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
              <div class="flex justify-end gap-2">
                <%= link_to produit, title: "Voir", class: "p-2 text-gray-400 hover:text-green-600 transition-colors" do %>
                  <%= heroicon "eye", options: { class: "w-5 h-5" } %>
                <% end %>
                <%= link_to edit_produit_path(produit), title: "Modifier", class: "p-2 text-gray-400 hover:text-green-600 transition-colors" do %>
                  <%= heroicon "pencil-square", options: { class: "w-5 h-5" } %>
                <% end %>
                <%= button_to produit, method: :delete, title: "Supprimer", class: "p-2 text-gray-400 hover:text-red-600 transition-colors", data: { turbo_confirm: "Confirmer la suppression ?" } do %>
                  <%= heroicon "trash", options: { class: "w-5 h-5" } %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @produits.empty? %>
      <div class="text-center py-20 bg-white">
        <%= heroicon "shopping-bag", options: { class: "w-16 h-16 mx-auto text-gray-200 mb-4" } %>
        <h3 class="text-xl font-bold text-gray-900">Aucun produit</h3>
        <p class="text-gray-500 mt-2">Commencez par ajouter des produits à votre catalogue.</p>
      </div>
    <% end %>
  </div>
</div>
