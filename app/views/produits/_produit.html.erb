<div id="<%= dom_id produit %>" class="flex flex-col md:flex-row gap-10 bg-white dark:bg-gray-800 p-10 rounded-3xl shadow-sm border border-gray-100 dark:border-white/10">
  <div class="md:w-1/3">
    <% if produit.image.attached? %>
      <%= image_tag produit.image.variant(resize_to_limit: [400, 400]), class: "w-full aspect-square object-cover rounded-2xl shadow-md border border-gray-100 dark:border-white/10" %>
    <% else %>
      <div class="w-full aspect-square bg-gradient-to-br from-gray-50 to-gray-100 dark:from-gray-700 dark:to-gray-800 flex items-center justify-center rounded-2xl border border-gray-200 dark:border-white/10 overflow-hidden">
        <%= image_tag "product_placeholder.png", class: "w-2/3 h-2/3 object-contain opacity-40 dark:opacity-30", alt: "Image produit non disponible" %>
      </div>
    <% end %>
  </div>

  <div class="flex-1">
    <div class="mb-8 flex items-center gap-3 flex-wrap">
      <span class="px-3 py-1 rounded-lg bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 text-xs font-black uppercase tracking-widest"><%= produit.category %></span>
      
      <% if produit.perime? %>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 text-xs font-black uppercase tracking-widest ring-1 ring-inset ring-red-600/10 dark:ring-red-400/20">
          <span class="size-1.5 rounded-full bg-red-500"></span>
          Périmé
        </span>
      <% else %>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400 text-xs font-black uppercase tracking-widest ring-1 ring-inset ring-green-600/10 dark:ring-green-400/20">
          <span class="size-1.5 rounded-full bg-green-500"></span>
          Bon état
        </span>
      <% end %>
      
      <h2 class="text-4xl font-black text-gray-900 dark:text-white mt-2 tracking-tight w-full"><%= produit.name %></h2>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 border-t border-gray-100 dark:border-white/5 pt-8">
      <div>
        <span class="block text-xs font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">Unité (UDM)</span>
        <p class="text-lg font-bold text-gray-700 dark:text-gray-300"><%= produit.udm %> (<%= produit.udm_value %>)</p>
      </div>
      <div>
        <span class="block text-xs font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">SKU</span>
        <p class="text-lg font-bold text-gray-700 dark:text-gray-300 font-mono"><%= produit.sku %></p>
      </div>
      <div class="md:col-span-2">
        <span class="block text-xs font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">Expiration (Dernière liste active)</span>
        <p class="text-lg font-bold text-gray-700 dark:text-gray-300 flex items-center gap-2">
          <%= heroicon "calendar", options: { class: "size-5 text-gray-400" } %>
          <% latest_item = produit.liste_de_prix_items.joins(:liste_de_prix).where(liste_de_prixes: { active: true }).order(created_at: :desc).first %>
          <%= l(latest_item.expiration_date, format: :long) if latest_item&.expiration_date %>
          <%= "Non spécifiée" if latest_item.nil? || latest_item.expiration_date.nil? %>
        </p>
      </div>
    </div>

    <% if produit.promotion? || (produit.bulk_sale_quantity.present? && produit.bulk_sale_quantity > 0) %>
      <div class="mt-8 flex flex-col gap-4">
        <% if produit.promotion? %>
          <div class="bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-100 dark:border-yellow-700/30 rounded-xl p-4">
            <div class="flex items-start justify-between">
              <div>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300 mb-2">
                  <span class="size-1.5 rounded-full bg-yellow-500"></span>
                  En Promotion
                </span>
                <p class="text-sm text-yellow-700 dark:text-yellow-400">
                  Du <%= l(produit.promotion_start_date) %> au <%= l(produit.promotion_end_date) %>
                </p>
              </div>
              <div class="text-right">
                <p class="text-2xl font-black text-yellow-600 dark:text-yellow-500"><%= number_to_currency(produit.promotion_price, unit: "FCFA", format: "%n %u", precision: 0) %></p>
                <p class="text-xs text-yellow-600/60 dark:text-yellow-500/60 font-medium">Prix Promo</p>
              </div>
            </div>
          </div>
        <% end %>

        <% if produit.bulk_sale_quantity.present? && produit.bulk_sale_quantity > 0 %>
          <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-100 dark:border-blue-700/30 rounded-xl p-4 flex items-center gap-4">
            <div class="bg-blue-100 dark:bg-blue-800 rounded-lg p-2 text-blue-600 dark:text-blue-300">
              <%= heroicon "archive-box", options: { class: "size-6" } %>
            </div>
            <div>
              <p class="font-bold text-blue-900 dark:text-blue-200">Vente en Gros</p>
              <p class="text-sm text-blue-700 dark:text-blue-300">
                <span class="font-bold"><%= number_to_percentage(produit.bulk_sale_discount_percentage, precision: 0) %> de réduction</span> 
                dès <%= produit.bulk_sale_quantity %> unités achetées
              </p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
