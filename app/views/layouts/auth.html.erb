<!DOCTYPE html>
<html class="h-full bg-gray-50 dark:bg-gray-900">
  <head>
    <script>
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark')
      } else {
        document.documentElement.classList.remove('dark')
      }
    </script>
    <title>ecoShop - Connexion</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script>
      // Configure Tailwind before it loads
      tailwind = {
        darkMode: 'class'
      }
    </script>
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography,aspect-ratio,line-clamp,container-queries"></script>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindplus/elements@1" type="module"></script>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full">
    <% if flash[:alert] %>
      <div class="fixed top-5 left-1/2 -translate-x-1/2 z-50 w-full max-w-md px-4">
        <div class="rounded-md bg-red-50 p-4 shadow-sm ring-1 ring-inset ring-red-600/10 dark:bg-red-900/50 dark:ring-red-500/20">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <p class="text-sm font-medium text-red-800 dark:text-red-200"><%= flash[:alert] %></p>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <% if flash[:notice] %>
      <div class="fixed top-5 left-1/2 -translate-x-1/2 z-50 w-full max-w-md px-4">
        <div class="rounded-md bg-green-50 p-4 shadow-sm ring-1 ring-inset ring-green-600/10 dark:bg-green-900/50 dark:ring-green-500/20">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <p class="text-sm font-medium text-green-800 dark:text-green-200"><%= flash[:notice] %></p>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>
