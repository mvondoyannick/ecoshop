<% if user_signed_in? %>
<nav class="bg-white dark:bg-gray-800 fixed w-full z-50 top-0 start-0 border-b border-gray-200 dark:border-white/10">
  <div class="max-w-screen-xl flex flex-wrap items-center justify-between mx-auto p-4">
    <%= link_to root_path, class: "flex items-center space-x-3 rtl:space-x-reverse" do %>
      <%= image_tag "logo.png", class: "h-10 w-auto", alt: "EcoShop Logo" %>
    <% end %>
    
    <div class="flex md:order-2 items-center space-x-3 md:space-x-0 rtl:space-x-reverse" data-controller="dark-mode">
        <!-- Dark mode toggle -->
        <button type="button" data-action="click->dark-mode#toggle" class="relative rounded-lg p-2 text-gray-500 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-700 focus:outline-none transition-colors">
          <span class="sr-only">Toggle dark mode</span>
          <!-- Sun icon (shown in dark mode) -->
          <svg class="size-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg class="size-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
          </svg>
        </button>

        <!-- Profile dropdown -->
        <el-dropdown class="relative">
          <button class="relative flex items-center gap-3 rounded-full focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-500 transition-all">
            <span class="absolute -inset-1.5"></span>
            <span class="sr-only">Open user menu</span>
            <div class="hidden md:flex flex-col items-end mr-1">
              <span class="text-xs font-bold text-gray-900 dark:text-white"><%= current_user.name %></span>
              <span class="text-[10px] text-gray-500 uppercase tracking-widest"><%= current_user.role&.name %></span>
            </div>
            <div class="size-9 rounded-full bg-green-600 flex items-center justify-center text-white text-sm font-bold shadow-sm ring-2 ring-white/10 ring-offset-2 ring-offset-white dark:ring-offset-gray-800">
              <%= current_user.name.to_s.first.upcase %>
            </div>
          </button>

          <el-menu anchor="bottom end" popover class="w-48 origin-top-right rounded-xl bg-white p-1 shadow-2xl outline-1 outline-black/5 transition transition-discrete [--anchor-gap:12px] dark:bg-gray-800 dark:shadow-none dark:-outline-offset-1 dark:outline-white/10">
            <div class="px-4 py-3 border-b border-gray-100 dark:border-white/5 md:hidden">
              <div class="text-sm font-bold text-gray-900 dark:text-white"><%= current_user.name %></div>
              <div class="text-xs text-gray-500"><%= current_user.role&.name %></div>
            </div>
            <a href="#" class="flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 dark:text-gray-300 dark:hover:bg-white/5 rounded-lg transition-colors">
              <svg class="size-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              Profil
            </a>
            <a href="#" class="flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 dark:text-gray-300 dark:hover:bg-white/5 rounded-lg transition-colors">
              <svg class="size-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              Paramètres
            </a>
            <div class="h-px bg-gray-100 dark:bg-white/5 my-1"></div>
            <%= button_to destroy_user_session_path, method: :delete, class: "w-full flex items-center gap-2 px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-900/20 rounded-lg transition-colors" do %>
              <svg class="size-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
              Déconnexion
            <% end %>
          </el-menu>
        </el-dropdown>

        <button type="button" command="--toggle" commandfor="navbar-dropdown" class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-gray-500 rounded-lg md:hidden hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200 dark:text-gray-400 dark:hover:bg-gray-700 dark:focus:ring-gray-600" aria-controls="navbar-dropdown" aria-expanded="false">
          <span class="sr-only">Open main menu</span>
          <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
          </svg>
        </button>
    </div>

    <div class="hidden w-full md:block md:w-auto md:order-1" id="navbar-dropdown">
      <ul class="flex flex-col font-medium p-4 md:p-0 mt-4 border border-gray-100 rounded-lg bg-gray-50 md:space-x-8 rtl:space-x-reverse md:flex-row md:mt-0 md:border-0 md:bg-white dark:bg-gray-800 md:dark:bg-gray-800 dark:border-gray-700">
        <li>
          <%= link_to root_path, class: "block py-2 px-3 rounded md:bg-transparent md:p-0 transition-colors #{current_page?(root_path) ? 'text-white bg-green-600 md:text-green-600 dark:md:text-green-400' : 'text-gray-900 hover:bg-gray-100 md:hover:bg-transparent md:hover:text-green-600 dark:text-white dark:hover:bg-gray-700 md:dark:hover:bg-transparent dark:md:hover:text-green-400'}", aria_current: ("page" if current_page?(root_path)) do %>
            Accueil
          <% end %>
        </li>
        
        <% if current_user.admin? || current_user.vendor? %>
          <li>
            <el-dropdown class="relative">
              <button class="flex items-center justify-between w-full py-2 px-3 text-gray-900 rounded hover:bg-gray-100 md:hover:bg-transparent md:border-0 md:hover:text-green-600 md:p-0 md:w-auto dark:text-white md:dark:hover:text-green-400 dark:hover:bg-gray-700 md:dark:hover:bg-transparent transition-colors">
                Global
                <svg class="w-2.5 h-2.5 ms-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                  <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"/>
                </svg>
              </button>
              <el-menu anchor="bottom start" popover class="z-10 w-44 font-medium bg-white rounded-xl shadow-2xl border border-gray-100 dark:bg-gray-800 dark:border-white/10 p-1 [--anchor-gap:16px] transition transition-discrete">
                <%= link_to villes_path, class: "block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 dark:text-gray-300 dark:hover:bg-white/5 rounded-lg transition-colors" do %>
                  Villes
                <% end %>
                <%= link_to societes_path, class: "block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 dark:text-gray-300 dark:hover:bg-white/5 rounded-lg transition-colors" do %>
                  Sociétés
                <% end %>
                <% if current_user.admin? %>
                  <div class="h-px bg-gray-100 dark:bg-white/5 my-1"></div>
                  <%= link_to terminal_accesses_path, class: "block px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-900/20 rounded-lg transition-colors" do %>
                    Sécurité (Accès)
                  <% end %>
                <% end %>
              </el-menu>
            </el-dropdown>
          </li>
          
          <li>
            <%= link_to supermarches_path, class: "block py-2 px-3 rounded md:p-0 transition-colors #{current_page?(supermarches_path) ? 'text-white bg-green-600 md:text-green-600 dark:md:text-green-400' : 'text-gray-900 hover:bg-gray-100 md:hover:bg-transparent md:hover:text-green-600 dark:text-white dark:hover:bg-gray-700 md:dark:hover:bg-transparent dark:md:hover:text-green-400'}" do %>
              Supermarchés
            <% end %>
          </li>
          
          <li>
            <%= link_to produits_path, class: "block py-2 px-3 rounded md:p-0 transition-colors #{current_page?(produits_path) ? 'text-white bg-green-600 md:text-green-600 dark:md:text-green-400' : 'text-gray-900 hover:bg-gray-100 md:hover:bg-transparent md:hover:text-green-600 dark:text-white dark:hover:bg-gray-700 md:dark:hover:bg-transparent dark:md:hover:text-green-400'}" do %>
              Produits
            <% end %>
          </li>
          
          <li>
            <%= link_to liste_de_prixes_path, class: "block py-2 px-3 rounded md:p-0 transition-colors #{current_page?(liste_de_prixes_path) ? 'text-white bg-green-600 md:text-green-600 dark:md:text-green-400' : 'text-gray-900 hover:bg-gray-100 md:hover:bg-transparent md:hover:text-green-600 dark:text-white dark:hover:bg-gray-700 md:dark:hover:bg-transparent dark:md:hover:text-green-400'}" do %>
              Prix
            <% end %>
          </li>

          <li>
            <el-dropdown class="relative">
              <button class="flex items-center justify-between w-full py-2 px-3 text-gray-900 rounded hover:bg-gray-100 md:hover:bg-transparent md:border-0 md:hover:text-green-600 md:p-0 md:w-auto dark:text-white md:dark:hover:text-green-400 dark:hover:bg-gray-700 md:dark:hover:bg-transparent transition-colors">
                Ventes
                <svg class="w-2.5 h-2.5 ms-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                  <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"/>
                </svg>
              </button>
              <el-menu anchor="bottom start" popover class="z-10 w-64 font-medium bg-white rounded-xl shadow-2xl border border-gray-100 dark:bg-gray-800 dark:border-white/10 p-1 [--anchor-gap:16px] transition transition-discrete">
                <div class="px-4 py-2 border-b border-gray-100 dark:border-white/5">
                  <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Gestion Commerciale</span>
                </div>
                <a href="#" class="flex flex-col gap-0.5 px-4 py-2.5 hover:bg-gray-50 dark:hover:bg-white/5 rounded-lg transition-colors group">
                  <span class="text-sm font-semibold text-gray-700 dark:text-gray-300 group-hover:text-green-600 dark:group-hover:text-green-400">Commandes</span>
                  <span class="text-[11px] text-gray-500">Suivi et historique des commandes</span>
                </a>
              </el-menu>
            </el-dropdown>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
  
  <!-- Mobile Menu Content -->
  <el-disclosure id="navbar-dropdown" hidden class="md:hidden">
    <div class="p-4 bg-gray-50 dark:bg-gray-900 border-t border-gray-100 dark:border-white/5">
      <ul class="space-y-1">
        <li>
          <%= link_to "Accueil", root_path, class: "block py-2.5 px-4 rounded-xl transition-colors #{current_page?(root_path) ? 'bg-green-600 text-white shadow-md' : 'text-gray-700 hover:bg-white dark:text-gray-300 dark:hover:bg-gray-800'}" %>
        </li>
        <% if current_user.admin? || current_user.vendor? %>
          <div class="pt-4 pb-1 px-4 text-[10px] font-bold text-gray-400 uppercase tracking-widest">Navigation</div>
          <li><%= link_to "Villes", villes_path, class: "block py-2.5 px-4 rounded-xl text-gray-700 hover:bg-white dark:text-gray-300 dark:hover:bg-gray-800" %></li>
          <li><%= link_to "Sociétés", societes_path, class: "block py-2.5 px-4 rounded-xl text-gray-700 hover:bg-white dark:text-gray-300 dark:hover:bg-gray-800" %></li>
          <li><%= link_to "Supermarchés", supermarches_path, class: "block py-2.5 px-4 rounded-xl text-gray-700 hover:bg-white dark:text-gray-300 dark:hover:bg-gray-800" %></li>
          <li><%= link_to "Produits", produits_path, class: "block py-2.5 px-4 rounded-xl text-gray-700 hover:bg-white dark:text-gray-300 dark:hover:bg-gray-800" %></li>
          <li><%= link_to "Prix", liste_de_prixes_path, class: "block py-2.5 px-4 rounded-xl text-gray-700 hover:bg-white dark:text-gray-300 dark:hover:bg-gray-800" %></li>
          <% if current_user.admin? %>
            <li><%= link_to "Sécurité", terminal_accesses_path, class: "block py-2.5 px-4 rounded-xl text-red-600 hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-900/20" %></li>
          <% end %>
          <div class="pt-4 pb-1 px-4 text-[10px] font-bold text-gray-400 uppercase tracking-widest">Ventes</div>
          <li><a href="#" class="block py-2.5 px-4 rounded-xl text-gray-700 hover:bg-white dark:text-gray-300 dark:hover:bg-gray-800">Commandes</a></li>
        <% end %>
      </ul>
    </div>
  </el-disclosure>
</nav>
<% end %>
