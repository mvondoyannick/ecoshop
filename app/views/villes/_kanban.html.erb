<div class="flex gap-6 overflow-x-auto pb-4">
  <% Ville::STATUSES.each do |status| %>
    <div class="flex-shrink-0 w-80 bg-gray-50 rounded-xl p-4 border border-gray-100">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-bold text-gray-700 flex items-center">
          <span class="w-3 h-3 rounded-full mr-2 <%= status_color(status).split(' ')[0] %>"></span>
          <%= status %>
        </h3>
        <span class="bg-gray-200 text-gray-700 text-xs font-bold px-2 py-1 rounded-full">
          <%= villes.select { |v| v.status == status }.count %>
        </span>
      </div>

      <div class="flex flex-col gap-3">
        <% villes.select { |v| v.status == status }.each do |ville| %>
          <div class="bg-white p-4 rounded-lg shadow-sm border border-gray-200 hover:shadow-md transition cursor-pointer group">
            <div class="flex justify-between items-start mb-2">
              <h4 class="font-semibold text-gray-900 capitalize"><%= ville.name %></h4>
              <span class="text-xs text-gray-400 group-hover:text-gray-600 transition"><%= ville.code %></span>
            </div>
            <div class="flex justify-between items-center mt-4">
              <div class="flex -space-x-1">
                <div class="w-6 h-6 rounded-full bg-blue-100 flex items-center justify-center text-[10px] text-blue-600 font-bold border border-white">
                  <%= ville.name[0] %>
                </div>
              </div>
              <div class="flex gap-3">
                <%= link_to "Voir", ville, class: "text-xs text-blue-500 hover:text-blue-700 font-medium" %>
                <%= link_to "Edit", edit_ville_path(ville), class: "text-xs text-gray-500 hover:text-gray-700 font-medium" %>
              </div>
            </div>
          </div>
        <% end %>

        <% if villes.select { |v| v.status == status }.empty? %>
          <div class="border-2 border-dashed border-gray-200 rounded-lg p-8 text-center">
            <p class="text-gray-400 text-sm">Vide</p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
