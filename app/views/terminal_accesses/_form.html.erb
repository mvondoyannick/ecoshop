<%= form_with(model: terminal_access, class: "contents") do |form| %>
  <% if terminal_access.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(terminal_access.errors.count, "error") %> prohibited this terminal_access from being saved:</h2>

      <ul class="list-disc ml-6">
        <% terminal_access.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :ip_address %>
    <%= form.text_field :ip_address, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": terminal_access.errors[:ip_address].none?, "border-red-400 focus:outline-red-600": terminal_access.errors[:ip_address].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :country %>
    <%= form.text_field :country, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": terminal_access.errors[:country].none?, "border-red-400 focus:outline-red-600": terminal_access.errors[:country].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :url %>
    <%= form.text_field :url, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": terminal_access.errors[:url].none?, "border-red-400 focus:outline-red-600": terminal_access.errors[:url].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :user_agent %>
    <%= form.text_area :user_agent, rows: 4, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": terminal_access.errors[:user_agent].none?, "border-red-400 focus:outline-red-600": terminal_access.errors[:user_agent].any?}] %>
  </div>

  <div class="my-5 flex items-center gap-2">
    <%= form.label :blocked %>
    <%= form.check_box :blocked, class: ["block shadow-sm rounded-md border order-first h-5 w-5", {"border-gray-400 focus:outline-blue-600": terminal_access.errors[:blocked].none?, "border-red-400 focus:outline-red-600": terminal_access.errors[:blocked].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
