<div id="<%= dom_id terminal_access %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Ip address:</strong>
    <%= terminal_access.ip_address %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Country:</strong>
    <%= terminal_access.country %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Url:</strong>
    <%= terminal_access.url %>
  </div>
  <div>
    <strong class="block font-medium mb-1">User agent:</strong>
    <%= terminal_access.user_agent %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Blocked:</strong>
    <%= terminal_access.blocked? ? "Yes" : "No" %>
  </div>
</div>
