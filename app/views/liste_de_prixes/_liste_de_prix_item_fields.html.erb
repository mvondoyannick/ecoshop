<div class="nested-fields flex flex-col gap-4 p-6 bg-gray-50 rounded-2xl border border-gray-100 relative group mb-4" data-new-record="<%= f.object.new_record? %>">
  <button type="button" data-action="nested-form#remove" class="absolute top-4 right-4 p-2 text-gray-400 hover:text-red-600 transition-colors">
    <%= heroicon "x-mark", options: { class: "size-5" } %>
  </button>

  <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
    <div class="md:col-span-2">
      <%= f.label :produit_id, "Produit", class: "block text-xs font-black text-gray-400 uppercase tracking-widest mb-1" %>
      <%= f.collection_select :produit_id, Produit.all, :id, :name, { prompt: "Sélectionnez un produit" }, class: "block w-full rounded-xl border-gray-200 text-sm focus:ring-green-500 focus:border-green-500" %>
    </div>
    <div>
      <%= f.label :price, "Prix", class: "block text-xs font-black text-gray-400 uppercase tracking-widest mb-1" %>
      <%= f.number_field :price, step: 0.01, class: "block w-full rounded-xl border-gray-200 text-sm focus:ring-green-500 focus:border-green-500" %>
    </div>
    <div>
      <%= f.label :discount_quantity, "Unité min.", class: "block text-xs font-black text-gray-400 uppercase tracking-widest mb-1" %>
      <%= f.number_field :discount_quantity, placeholder: "1", class: "block w-full rounded-xl border-gray-200 text-sm focus:ring-green-500 focus:border-green-500" %>
    </div>
    <div>
      <%= f.label :expiration_date, "Péremption", class: "block text-xs font-black text-gray-400 uppercase tracking-widest mb-1" %>
      <%= f.date_field :expiration_date, class: "block w-full rounded-xl border-gray-200 text-sm focus:ring-green-500 focus:border-green-500" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
    <div>
      <%= f.label :start_date, "Début", class: "block text-xs font-black text-gray-400 uppercase tracking-widest mb-1" %>
      <%= f.date_field :start_date, class: "block w-full rounded-xl border-gray-200 text-sm focus:ring-green-500 focus:border-green-500" %>
    </div>
    <div>
      <%= f.label :end_date, "Fin", class: "block text-xs font-black text-gray-400 uppercase tracking-widest mb-1" %>
      <%= f.date_field :end_date, class: "block w-full rounded-xl border-gray-200 text-sm focus:ring-green-500 focus:border-green-500" %>
    </div>
    <div>
      <%= f.label :discount, "Réduction", class: "block text-xs font-black text-gray-400 uppercase tracking-widest mb-1" %>
      <%= f.number_field :discount, step: 0.01, class: "block w-full rounded-xl border-gray-200 text-sm focus:ring-green-500 focus:border-green-500" %>
    </div>
    <div>
      <%= f.label :discount_type, "Type Réd.", class: "block text-xs font-black text-gray-400 uppercase tracking-widest mb-1" %>
      <%= f.select :discount_type, ["Pourcentage", "Fixe"], {}, class: "block w-full rounded-xl border-gray-200 text-sm focus:ring-green-500 focus:border-green-500" %>
    </div>
  </div>

  <%= f.hidden_field :_destroy %>
</div>
